# ── AI provider (Anthropic) ──────────────────────────────────────────────────
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model ids (see the provider's model list)
AI_MODEL=
AI_MODEL_FAST=

# ── Security ──────────────────────────────────────────────────────────────────
# Master secret for encrypting profiles at rest + signing sessions.
# Leave blank to auto-generate on first run (stored in data/.secret).
AUDRI_SECRET=
# Required in production. Protects cron and administrative ingestion routes.
CRON_SECRET=

# ── Paywall / Billing ─────────────────────────────────────────────────────────
AUDRI_FREE_ESSAYS=3
AUDRI_ACTIVATION_SECRET=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Audri

# Set true when an external scheduler such as Vercel Cron owns ingestion.
DISABLE_SCRAPE_SCHEDULER=false
