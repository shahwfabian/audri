# Managed AI provider, server-only. Never expose these as NEXT_PUBLIC variables.
ANTHROPIC_API_KEY=
AI_MODEL=
AI_MODEL_FAST=

# Security
# Use a stable random value of at least 32 bytes in production.
AUDRI_SECRET=
CRON_SECRET=

# Production database
# Apply the SQL files in supabase/migrations before launch.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Enable only after custom SMTP is configured in Supabase.
AUDRI_REQUIRE_EMAIL_VERIFICATION=true

# Billing
AUDRI_FREE_ESSAYS=2
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Backward-compatible fallback for the $9 Student plan.
STRIPE_PRO_PRICE_ID=
STRIPE_STUDENT_PRICE_ID=
STRIPE_POWER_PRICE_ID=
STRIPE_SPRINT_PRICE_ID=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# Support-only activation fallback. Leave disabled for normal billing.
AUDRI_ALLOW_MANUAL_ACTIVATION=false
AUDRI_ACTIVATION_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Audri
NEXT_PUBLIC_SUPPORT_EMAIL=

# Set true when an external scheduler owns ingestion.
DISABLE_SCRAPE_SCHEDULER=false
