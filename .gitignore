# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local autoresearch output
/research/runs/

# local server launch logs
/.audri-*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Encrypted user store + generated secret (never commit)
/data/users.json
/data/users.test.*.json
/data/users.json.*.tmp
/data/users.test.*.json.*.tmp
/data/.secret

# ...but do commit the template
!.env.example
